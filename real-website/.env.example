# Razorpay API Keys
# Get your keys from https://dashboard.razorpay.com/app/keys
# Use test-mode keys (rzp_test_...) for local development
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Razorpay Webhook Secret (from Dashboard → Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Google Drive Delivery
# Paste the full service account JSON as a single line (minify it first)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# The folder ID from your Drive URL: drive.google.com/drive/folders/<THIS_ID>
GDRIVE_FOLDER_ID=your_folder_id_here

# Resend Email (resend.com)
RESEND_API_KEY=re_your_api_key_here
# Optional: override default sender address
RESEND_FROM_EMAIL=Code Hunters <noreply@codehunters.dev>

# Server
PORT=3000
